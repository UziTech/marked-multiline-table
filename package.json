{
  "name": "marked-multiline-table",
  "version": "1.2.1",
  "description": "A marked extension to support multiline tables in markdown.",
  "main": "./lib/index.esm.js",
  "module": "./lib/index.esm.js",
  "browser": "./lib/index.umd.js",
  "type": "module",
  "keywords": [
    "marked",
    "extension"
  ],
  "files": [
    "lib/",
    "src/"
  ],
  "exports": {
    ".": {
      "typescript": "./src/index.ts",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.esm.js"
    }
  },
  "scripts": {
    "build": "npm run build:esbuild && npm run build:types",
    "build:esbuild": "node esbuild.config.ts",
    "build:types": "tsc && dts-bundle-generator --export-referenced-types --project tsconfig.json -o lib/index.d.ts src/index.ts",
    "format": "eslint --fix",
    "lint": "eslint",
    "test": "npm run build:esbuild && node ./spec/test.config.ts",
    "test:cover": "npm run build:esbuild && node --experimental-test-coverage ./spec/test.config.ts -- --cover",
    "test:only": "npm run build:esbuild && node ./spec/test.config.ts -- --only",
    "test:types": "npm run build:types && tsc --project tsconfig-test-types.json && attw -P --entrypoints . --profile esm-only",
    "test:update": "npm run build:esbuild && node --test-update-snapshots ./spec/test.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UziTech/marked-multiline-table.git"
  },
  "author": "Tony Brix <Tony@Brix.ninja> (https://Tony.Brix.ninja)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/UziTech/marked-multiline-table/issues"
  },
  "homepage": "https://github.com/UziTech/marked-multiline-table#readme",
  "peerDependencies": {
    "marked": ">=18 <19"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@markedjs/eslint-config": "^1.0.14",
    "@markedjs/testutils": "^18.0.0-1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@types/node": "^26.0.0",
    "dts-bundle-generator": "^9.5.1",
    "esbuild": "^0.28.1",
    "esbuild-plugin-umd-wrapper": "^3.0.0",
    "eslint": "^10.5.0",
    "jiti": "^2.7.0",
    "marked": "^18.0.5",
    "semantic-release": "^25.0.5",
    "typescript": "^6.0.3"
  }
}
